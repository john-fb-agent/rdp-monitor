{
  "name": "rdp-monitor",
  "version": "1.0.0",
  "description": "Windows RDP Port 3389 Monitor with Telegram Notifications",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "watch": "tsc -w",
    "install-task": "node scripts/install-task.js",
    "uninstall-task": "node scripts/uninstall-task.js",
    "test-notification": "node dist/test-notification.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "rdp",
    "monitor",
    "windows",
    "port-3389",
    "telegram",
    "task-scheduler"
  ],
  "author": "john-fb-agent",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
